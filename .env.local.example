# Copie esse arquivo pra .env.local e preencha as chaves
# .env.local NUNCA é commitado (já está no .gitignore)

# Site
NEXT_PUBLIC_SITE_URL=https://gtoverlander.com.br

# Sanity (CMS do blog) - peguei na dashboard sanity.io após criar o projeto
# 1. Login em sanity.io → criar projeto novo
# 2. Copiar Project ID (sanity.io/manage → Project Settings)
# 3. Dataset default é "production"
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Opcional: token de leitura pra dataset privado (pode deixar vazio se dataset público)
SANITY_API_READ_TOKEN=

# Resend (envio de e-mails dos forms) - pegue em resend.com/api-keys
RESEND_API_KEY=

# Sentry (monitoramento de erros)
# DSN: pegue em sentry.io → seu projeto → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
# Org slug: aparece na URL do Sentry (https://sentry.io/organizations/SUA_ORG/)
SENTRY_ORG=
# Project slug: nome do projeto criado no Sentry
SENTRY_PROJECT=gtoverlander-site
# Auth token (build-time, pra upload de source maps)
# Sentry → Settings → Auth Tokens → Create New Token (scope: project:write)
SENTRY_AUTH_TOKEN=

# Plausible (analytics) - dominio cadastrado em plausible.io
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=gtoverlander.com.br
# PLAUSIBLE_API_KEY só se precisar puxar stats programaticamente
PLAUSIBLE_API_KEY=
